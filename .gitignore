# macOS
.DS_Store

# Node / Astro build output (per-project)
**/node_modules/
**/dist/
**/.astro/
**/.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files
.env
.env.local
.env.*.local

# Editor
.vscode/
.idea/

# Temp / scratch
*.tmp
*.swp
.git.broken-*/

# FUSE filesystem leftovers (sandbox edits over a FUSE mount create these;
# they are not real files and must never be committed)
**/.fuse_hidden*
