---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';
import { withBase } from '../../lib/urls';
import { currentEdition, editions } from '../../lib/editions';
import { inlineCover } from '../../lib/inlineCover';

// ---------------------------------------------------------------------------
// Pieces — the Arabic home draws on:
//   (1) the Arabic content collection (articles-ar) when populated, and
//   (2) the English collection to surface any pieces that carry Arabic
//       inline-blocks readers can preview here.
// For v0.1, (1) is empty and (2) gives us Piece B (Jordan).
// ---------------------------------------------------------------------------
const arPieces = await getCollection('articles-ar', ({ data }) => data.approved !== false);
const enPieces = await getCollection('articles', ({ data }) => data.approved !== false);

const sortedAr = arPieces.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedEn = enPieces.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatterAr = new Intl.DateTimeFormat('ar-EG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Inline wordmark — try multiple candidate paths so a difference in how
// Astro resolves import.meta.url between EN and AR pages doesn't silently
// fall back to the typographic mark.
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
function loadWordmark(): string | null {
  const candidates = [
    resolve(__dirname, '../../../public/wordmark/madar-wordmark.svg'),
    resolve(__dirname, '../../public/wordmark/madar-wordmark.svg'),
    resolve(__dirname, '../../../../design-assets/wordmark/madar-wordmark.svg'),
    resolve(__dirname, '../../../design-assets/wordmark/madar-wordmark.svg'),
  ];
  for (const p of candidates) {
    if (existsSync(p)) {
      try {
        return readFileSync(p, 'utf-8')
          .replace(/^<\?xml[^?]*\?>\s*/, '')
          .replace(/<!--[\s\S]*?-->/g, '');
      } catch { /* try next */ }
    }
  }
  return null;
}
const wordmarkSvg = loadWordmark();

// The Arabic home page's "from-the-issue" excerpts block previously surfaced
// excerpts from the Jordan piece (Issue 01, secondary). That piece was parked
// by the Editor on 2026-05-26 over source verification. The excerpt block is
// retired with it; the Arabic home renders the placeholder + about until the
// Arabic collection is populated. See /content-drafts/parked/2026-05-25-jordan-double-shift/parked.md.
const issueExcerpts: { ar: string; en: string }[] = [];

// ---------------------------------------------------------------------------
// The Arabic home leads with the CURRENT edition. Scope the Arabic pieces to
// that edition; surface previous (closed) editions in the strip below.
// ---------------------------------------------------------------------------
const editionPieces = sortedAr.filter((p) => p.data.edition === currentEdition.number);
const edNum = String(currentEdition.number).padStart(2, '0');
const edLabelAr = `الإصدار ${currentEdition.number}`;

const previousEditions = editions
  .filter((e) => e.status === 'closed')
  .sort((a, b) => b.number - a.number);
function editionPieceCount(n: number): number {
  return sortedAr.filter((p) => p.data.edition === n).length;
}
---

<Base title="مدار — التعليم، بتأنٍّ، بلغتين" lang="ar" noHeader={true}>

  {/* ============== TOP UTILITY BAR ============== */}
  <div class="top-bar">
    <div class="top-bar__inner container">
      <div class="top-bar__left">
        <span lang="ar" dir="rtl">{edLabelAr} · {currentEdition.periodAr} · مدار</span>
      </div>
      <div class="top-bar__right">
        <span class="top-bar__lang">
          <a href={withBase('/')} lang="en">EN</a>
          <span aria-hidden="true">·</span>
          <a href={withBase('/ar/')} class="is-active" lang="ar" dir="rtl">عربي</a>
        </span>
      </div>
    </div>
  </div>

  {/* ============== MASTHEAD ============== */}
  <header class="masthead">
    <div class="masthead__inner container">
      <a href={withBase('/ar/')} class="masthead__mark" aria-label="مدار — الرئيسية">
        {wordmarkSvg ? (
          <Fragment set:html={wordmarkSvg} />
        ) : (
          <span class="masthead__fallback" lang="ar" dir="rtl">مدار</span>
        )}
      </a>

      <div class="masthead__rule" aria-hidden="true"></div>

      <p class="masthead__tagline" lang="ar" dir="rtl">
        التعليم، بتأنٍّ، بلغتين
      </p>
    </div>
  </header>

  {/* ============== CURRENT EDITION ============== */}
  <section
    class="section container current-edition"
    style={`--ed-ground:${currentEdition.ground};--ed-accent:${currentEdition.accent};`}
  >
    {inlineCover(currentEdition.cover) && (
      <div class="current-edition__cover" set:html={inlineCover(currentEdition.cover)} />
    )}

    <div class="section__head">
      <div class="section__head-left">
        <span class="section__kicker" lang="ar" dir="rtl">الإصدار الحالي</span>
        <p class="current-edition__theme" lang="ar" dir="rtl">{edLabelAr} — {currentEdition.themeAr}</p>
      </div>
      <span class="section__meta" lang="ar" dir="rtl">{edLabelAr} · {currentEdition.periodAr}</span>
    </div>

    {editionPieces.length === 0 && (
      <div class="placeholder">
        <p lang="ar" dir="rtl" class="placeholder__lead">
          لم يصدر بعد عددٌ عربيٌّ مكتمل. حتى ذلك الحين، يمكنك قراءة المقالات الإنجليزية على
          <a href={withBase('/')}>الصفحة الإنجليزية</a>.
        </p>
        <p lang="ar" dir="rtl" class="muted">
          النسخةُ العربيّةُ من هذا الإصدار قيدُ الإعداد. سَتظهرُ هنا حالَ اكتمالِها.
        </p>
      </div>
    )}

    {editionPieces.length > 0 && (
      <ul class="piece-list">
        {editionPieces.map((piece) => (
          <li class="piece">
            <a href={withBase(`/ar/articles/${piece.id}/`)} class="piece__link">
              <span class="piece__meta">
                <span class="piece__country" lang="ar" dir="rtl">{piece.data.country}</span>
                <span class="piece__date">{dateFormatterAr.format(piece.data.date)}</span>
              </span>
              <h2 class="piece__title" lang="ar" dir="rtl">{piece.data.title}</h2>
              {piece.data.dek && <p class="piece__dek" lang="ar" dir="rtl">{piece.data.dek}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  {/* The from-the-issue Arabic excerpts block was retired on 2026-05-26 when
       the source piece (Jordan double-shift) was parked. The block returns
       when an Arabic-first piece is added to the articles-ar collection. */}

  {/* ============== PREVIOUS EDITIONS STRIP ============== */}
  {previousEditions.length > 0 && (
    <section class="prev-editions container">
      <div class="prev-editions__head">
        <span class="prev-editions__label" lang="ar" dir="rtl">إصدارات سابقة</span>
        <a class="prev-editions__browse" href={withBase('/ar/editions/')} lang="ar" dir="rtl">تصفّح كل الإصدارات ←</a>
      </div>
      <ul class="prev-editions__grid">
        {previousEditions.map((ed) => {
          const n = String(ed.number).padStart(2, '0');
          const count = editionPieceCount(ed.number);
          return (
            <li class="prev-edition">
              <a href={withBase('/ar/editions/')} class="prev-edition__link" aria-label={`الإصدار ${ed.number} — ${ed.periodAr}`}>
                <span class="prev-edition__cover">
                  <img
                    src={withBase('/covers/' + ed.cover)}
                    alt={`مدار — غلاف الإصدار ${ed.number}`}
                    loading="lazy"
                    width="160"
                    height="207"
                  />
                </span>
                <span class="prev-edition__meta" lang="ar" dir="rtl">
                  <span class="prev-edition__num">الإصدار {ed.number}</span>
                  <span class="prev-edition__period">{ed.periodAr}</span>
                  <span class="prev-edition__count">{count} {count === 1 ? 'مادة' : 'مواد'}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {/* ============== ABOUT MINI ============== */}
  <section class="about container">
    <div class="about__head">
      <p class="about__label" lang="ar" dir="rtl">عن مدار</p>
    </div>
    <div class="about__body" lang="ar" dir="rtl">
      <p>
        «مدار» مجلّةٌ تحريريّةٌ بطيئةُ الإيقاع تَتناولُ التعليمَ في مرحلتَيِ الطفولةِ
        المبكّرةِ والتعليمِ العامّ، تَصدرُ بالعربيّةِ والإنجليزيّة. ننشرُ نوعَين من
        المواد: <em>تقاريرَ ميدانيّة</em> نَكتبُها بأنفسنا، و<em>قراءاتٍ مختاَرة</em>
        لمصدرٍ واحدٍ يَستحقّ الإصغاء. أداةُ بحثٍ، لا مجلّةً.
      </p>
      <p>
        نكتبُ من مدارٍ واحدٍ بلغتَين، ولكلٍّ منهما وزنُها الخاصّ.
      </p>
    </div>
  </section>

</Base>

<style>
  .top-bar {
    border-block-end: 1px solid var(--color-rule-soft);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .top-bar__inner {
    padding-block: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .top-bar__lang a { text-decoration: none; color: var(--color-ink); opacity: 0.6; }
  .top-bar__lang a.is-active { color: var(--color-orange); opacity: 1; font-weight: 500; }
  .top-bar__lang span { opacity: 0.35; }

  .masthead {
    border-block-end: 1px solid var(--color-rule);
    padding-block: 4rem 3rem;
    text-align: center;
  }
  .masthead__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }
  .masthead__mark { display: inline-block; text-decoration: none; color: var(--color-ink); }
  .masthead__mark :global(svg) { width: auto; height: 120px; color: var(--color-ink); display: block; }
  .masthead__fallback {
    font-family: var(--font-arabic-display); font-size: 72px; font-weight: 500; line-height: 1;
  }
  .masthead__rule { height: 1px; background: var(--color-ink); width: 120px; position: relative; }
  .masthead__rule::before, .masthead__rule::after {
    content: ''; position: absolute; inset-block-start: -4px; width: 1px; height: 9px; background: var(--color-ink);
  }
  .masthead__rule::before { inset-inline-start: 0; }
  .masthead__rule::after  { inset-inline-end: 0; }
  .masthead__tagline {
    margin: 0;
    font-family: var(--font-arabic);
    font-size: 19px;
    line-height: 1.8;
    color: var(--color-ink);
    opacity: 0.85;
    max-width: 42ch;
  }

  .section { padding-block: 3.5rem; }
  .section__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-block-end: 2rem;
  }
  .section__head-left { display: flex; flex-direction: column; gap: 0.4rem; }
  .section__kicker {
    font-family: var(--font-arabic-display);
    font-size: 22px;
    color: var(--color-orange);
    font-weight: 500;
  }

  /* ---------- Current edition (themed) ---------- */
  .current-edition {
    border-radius: 2px;
    background:
      linear-gradient(0deg,
        color-mix(in srgb, var(--ed-ground) 55%, transparent),
        color-mix(in srgb, var(--ed-ground) 55%, transparent));
  }
  .current-edition__cover {
    max-width: 360px;
    margin-inline: auto;
    margin-block-end: 2.5rem;
  }
  .current-edition__cover :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .current-edition .section__kicker { color: var(--ed-accent); }
  .current-edition__theme {
    margin: 0;
    font-family: var(--font-arabic);
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.9;
    max-width: 50ch;
  }
  .current-edition .piece__meta { color: var(--ed-accent); }
  .current-edition .piece__link:hover .piece__title { color: var(--ed-accent); }
  .section__meta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.62;
  }

  .placeholder { padding-block: var(--space-md); }
  .placeholder__lead {
    font-family: var(--font-arabic);
    font-size: 19px;
    line-height: 1.9;
    color: var(--color-ink);
  }
  .placeholder__lead a {
    color: var(--color-orange);
    text-decoration-color: var(--color-orange);
  }

  .piece-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 2rem; }
  .piece__link { display: block; text-decoration: none; color: var(--color-ink); }
  .piece__meta {
    display: flex; justify-content: space-between; gap: 1rem;
    font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-orange);
  }
  .piece__title { margin-block: 0.5rem 0; font-family: var(--font-arabic-display); font-size: 28px; line-height: 1.4; }
  .piece__dek { margin-block-start: 0.5rem; font-family: var(--font-arabic); font-size: 17px; line-height: 1.85; opacity: 0.82; }

  /* Arabic excerpts block — when sortedAr is empty but English Jordan piece exists */
  .excerpts {
    padding-block: 2.5rem 3.5rem;
    border-block-start: 1px solid var(--color-rule);
  }
  .excerpts__head { margin-block-end: 1.5rem; }
  .excerpts__lead {
    font-family: var(--font-arabic);
    font-size: 17.5px;
    line-height: 1.85;
    margin: 0.5rem 0 0;
    color: var(--color-ink);
    opacity: 0.85;
  }
  .excerpts__lead a {
    color: var(--color-orange);
    text-decoration-color: var(--color-orange);
  }
  .excerpts__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.5rem; }
  .excerpt {
    padding: 1.25rem 1.5rem;
    border-inline-end: 2px solid var(--color-orange);
    background: rgba(232, 226, 208, 0.25);
  }
  .excerpt__ar {
    margin: 0;
    font-family: var(--font-arabic-display);
    font-size: 28px;
    line-height: 1.5;
    color: var(--color-ink);
  }
  .excerpt__en {
    margin: 0.5rem 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  /* ---------- Previous editions strip ---------- */
  .prev-editions {
    padding-block: 2.5rem 1rem;
    border-block-start: 1px solid var(--color-rule);
    margin-block-start: 1.5rem;
  }
  .prev-editions__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-block-end: 1.75rem;
  }
  .prev-editions__label {
    font-family: var(--font-arabic-display);
    font-size: 20px;
    color: var(--color-ink);
    opacity: 0.85;
    font-weight: 500;
  }
  .prev-editions__browse {
    font-family: var(--font-arabic);
    font-size: 15px;
    color: var(--color-orange);
    text-decoration: none;
    border-block-end: 1px solid var(--color-orange);
    padding-block-end: 2px;
  }
  .prev-editions__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2rem;
  }
  .prev-edition__link {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    text-decoration: none;
    color: var(--color-ink);
  }
  .prev-edition__cover {
    flex: 0 0 auto;
    display: block;
    border: 1px solid var(--color-rule-soft);
    border-radius: 2px;
    overflow: hidden;
    background: var(--color-sand);
  }
  .prev-edition__cover img {
    display: block;
    width: 80px;
    height: auto;
  }
  .prev-edition__meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-family: var(--font-arabic);
    font-size: 14px;
    padding-block-start: 0.2rem;
  }
  .prev-edition__num {
    font-size: 16px;
    color: var(--color-ink);
    font-weight: 500;
    font-family: var(--font-arabic-display);
  }
  .prev-edition__period { color: var(--color-ink); opacity: 0.65; }
  .prev-edition__count { color: var(--color-sage); }
  .prev-edition__link:hover .prev-edition__num { color: var(--color-orange); }

  .about { padding-block: 3rem 4rem; }
  .about__label {
    font-family: var(--font-arabic-display);
    font-size: 22px;
    color: var(--color-orange);
    margin: 0 0 0.85rem;
  }
  .about__body p {
    font-family: var(--font-arabic);
    font-size: 18.5px;
    line-height: 1.95;
    margin: 0 0 1rem;
    max-width: 52ch;
  }

  @media (max-width: 720px) {
    .masthead { padding-block: 2.5rem 2rem; }
    .masthead__mark :global(svg) { height: 88px; }
    .masthead__fallback { font-size: 50px; }
    .section { padding-block: 2.5rem; }
  }
</style>
