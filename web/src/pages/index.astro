---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/urls';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

// ---------------------------------------------------------------------------
// Inline the wordmark SVG at build time. The SVG uses fill="currentColor" so
// when inlined it inherits .masthead__mark's color (var(--color-ink)). Loading
// it via <img src> as we did previously made it (a) dependent on a separate
// network round-trip, (b) stuck at the SVG's default black instead of the
// theme ink, and (c) silently fail if the file is missing — no typographic
// fallback was visible. Inlining + CSS-only fallback fixes all three.
// ---------------------------------------------------------------------------
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

function loadWordmark(): string | null {
  // Prefer /web/public (what the Astro build actually ships); fall back to the
  // canonical /design-assets master copy if /public hasn't been synced yet.
  const candidates = [
    resolve(__dirname, '../../public/wordmark/madar-wordmark.svg'),
    resolve(__dirname, '../../../design-assets/wordmark/madar-wordmark.svg'),
  ];
  for (const p of candidates) {
    if (existsSync(p)) {
      try {
        let svg = readFileSync(p, 'utf-8');
        svg = svg.replace(/^<\?xml[^?]*\?>\s*/, '');
        return svg;
      } catch { /* fall through */ }
    }
  }
  return null;
}
const wordmarkSvg = loadWordmark();

// ---------------------------------------------------------------------------
// Pieces — only those approved appear in the latest list.
// ---------------------------------------------------------------------------
const all = await getCollection('articles', ({ data }) => data.approved !== false);
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// ---------------------------------------------------------------------------
// Lead / secondary split for the editorial hierarchy on the home page.
// For v0.1 we pin the lead by slug — Sierra Leone (Piece A) is the issue's
// editorial centre — and treat the remaining approved pieces as the secondary
// register. This keeps the design intent stable while we figure out the right
// long-term lead-selection rule.
// TODO: revisit lead-selection logic post-v0.1 (most-recent? Editor-flagged
// `lead: true` in frontmatter? hand-curated weekly?).
// ---------------------------------------------------------------------------
const LEAD_SLUG = '2026-05-25-bo-teacher-chalk';
const lead = sorted.find((p) => p.id === LEAD_SLUG) ?? sorted[0];
const secondary = sorted.filter((p) => p && p.id !== lead?.id);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const placeholder = sorted.length === 0;

// "Draft — pending source verification" pill flag per piece
function hasProvisionalSources(p: typeof sorted[number]): boolean {
  return p.data.sources.some((s) => /PLACEHOLDER SOURCE/i.test(s.title));
}

const fieldLabel: Record<string, string> = {
  curated: 'Curated',
  short: 'Field Note',
  essay: 'Essay',
};

function kickerFor(piece: typeof sorted[number], i: number): string {
  const num = String(i + 1).padStart(2, '0');
  const label = fieldLabel[piece.data.type] ?? 'Piece';
  const register = piece.data.type === 'curated' ? 'Curated' : 'Editorial';
  return `${label} ${num} · ${register}`;
}
---

<Base title="Madār · مدار — Issue 01" lang="en" noHeader={true}>

  {/* ============== TOP UTILITY BAR ============== */}
  <div class="top-bar">
    <div class="top-bar__inner container">
      <div class="top-bar__left">
        Issue 01 · May 2026 <span lang="ar" dir="rtl">· مدار</span>
      </div>
      <div class="top-bar__right">
        <span class="top-bar__meta">A research instrument</span>
        <span class="top-bar__lang">
          <a href={withBase('/')} class="is-active" lang="en">EN</a>
          <span aria-hidden="true">·</span>
          <a href={withBase('/ar/')} lang="ar" dir="rtl">عربي</a>
        </span>
      </div>
    </div>
  </div>

  {/* ============== MASTHEAD ============== */}
  <header class="masthead">
    <div class="masthead__inner container">
      <a href={withBase('/')} class="masthead__mark" aria-label="Madār — home">
        {wordmarkSvg ? (
          <Fragment set:html={wordmarkSvg} />
        ) : (
          <Fragment>
            {/* Typographic fallback — visible if the SVG ever fails to load. */}
            <span class="masthead__mark-latin">Madār</span>
            <span class="masthead__mark-divider" aria-hidden="true">·</span>
            <span class="masthead__mark-arabic" lang="ar" dir="rtl">مدار</span>
          </Fragment>
        )}
      </a>

      <div class="masthead__rule" aria-hidden="true"></div>

      <p class="masthead__tagline">
        Education, written slowly, in two languages
        <span class="masthead__tagline-ar" lang="ar" dir="rtl">التعليم، بتأنٍّ، بلغتين</span>
      </p>
    </div>
  </header>
  {/* ============== THIS WEEK ============== */}
  <section class="section container">
    <div class="section__head">
      <div class="section__head-left">
        <span class="section__kicker">This week</span>
        <span class="section__kicker-ar" lang="ar" dir="rtl">هذا الأسبوع</span>
      </div>
      <div class="section__meta">
        Issue 01 · 2026 · 05 · 25 · {sorted.length} piece{sorted.length === 1 ? '' : 's'}
      </div>
    </div>

    {placeholder && (
      <div class="placeholder">
        <p class="uppercase muted">Pre-launch</p>
        <h2>The publication has not yet published its first piece.</h2>
        <p class="muted measure">
          When the Editor's seed pieces are approved by the founder, they appear here.
          Until then, this page is a deliberate blank — a reminder that nothing ships
          before it passes the quality bar.
        </p>
      </div>
    )}

    {!placeholder && lead && (() => {
      const draft = hasProvisionalSources(lead);
      const kicker = kickerFor(lead, 0);
      const thumb = withBase(lead.data.hero?.src ?? `/stills/${lead.id}.svg`);
      const alt = lead.data.hero?.alt ?? lead.data.title;
      const articleHref = withBase(`/articles/${lead.id}/`);
      return (
        <article class="lead">
          <a href={articleHref} class="lead__thumb" aria-label={`Read this issue's lead — ${lead.data.title}`}>
            <img src={thumb} alt={alt} width="800" height="500" loading="eager" decoding="async" />
          </a>
          <div class="lead__body">
            <span class="lead__label">Read this issue's lead</span>
            <div class="lead__meta">
              <span class="lead__type">{kicker}</span>
              <span class="lead__country">{lead.data.country}</span>
            </div>
            <h2 class="lead__title">
              <a href={articleHref}>{lead.data.title}</a>
            </h2>
            {lead.data.dek && <p class="lead__dek">{lead.data.dek}</p>}
            <div class="lead__byline">
              By The Editors · {dateFormatter.format(lead.data.date)}
              {draft && (
                <>
                  {' · '}
                  <span class="pill">Draft — pending source verification</span>
                </>
              )}
            </div>
            <a class="lead__read" href={articleHref}>Read the lead piece →</a>
          </div>
        </article>
      );
    })()}

    {!placeholder && secondary.length > 0 && (
      <section class="also">
        <div class="also__head">
          <div>
            <span class="also__label">Also this issue</span>
            <span class="also__label-ar" lang="ar" dir="rtl">من هذا العدد أيضاً</span>
          </div>
          <div class="also__meta">
            {secondary.length} piece{secondary.length === 1 ? '' : 's'} · Issue 01
          </div>
        </div>

        <div class="also__grid">
          {secondary.map((piece, i) => {
            const draft = hasProvisionalSources(piece);
            // Numbering picks up after the lead so secondary kickers read 02, 03, …
            const kicker = kickerFor(piece, i + 1);
            const thumb = withBase(piece.data.hero?.src ?? `/stills/${piece.id}.svg`);
            const alt = piece.data.hero?.alt ?? piece.data.title;
            const articleHref = withBase(`/articles/${piece.id}/`);
            return (
              <article class="secondary">
                <a href={articleHref} class="secondary__thumb" aria-label={`Also this issue — ${piece.data.title}`}>
                  <img src={thumb} alt={alt} width="360" height="240" loading="lazy" decoding="async" />
                </a>
                <div class="secondary__body">
                  <div class="secondary__meta">
                    <span class="secondary__type">{kicker}</span>
                    <span class="secondary__country">{piece.data.country}</span>
                  </div>
                  <h3 class="secondary__title">
                    <a href={articleHref}>{piece.data.title}</a>
                  </h3>
                  {piece.data.dek && <p class="secondary__dek">{piece.data.dek}</p>}
                  <div class="secondary__byline">
                    By The Editors · {dateFormatter.format(piece.data.date)}
                    {draft && (
                      <>
                        {' · '}
                        <span class="pill">Draft — pending source verification</span>
                      </>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}
  </section>

  {/* ============== MACRON DIVIDER ============== */}
  <div class="macron-divider" aria-hidden="true">
    <span class="macron-divider__rule"></span>
  </div>

  {/* ============== ABOUT MINI-BLOCK ============== */}
  <section class="about container">
    <div class="about__head">
      <p class="about__label">About</p>
      <p class="about__label-ar" lang="ar" dir="rtl">عن مدار</p>
    </div>
    <div class="about__body">
      <div class="about__col en">
        <p>
          Madār is a slow-cadence editorial publication on early childhood and
          K-12 education, written in English and Arabic. We publish two kinds of
          pieces: <em>field notes</em> we report ourselves, and <em>curated
          readings</em> of one carefully-chosen source worth listening to. Two
          to three pieces an issue. One issue a month. A research instrument,
          not a magazine.
        </p>
        <p>
          <a href={withBase('/about/')} class="about__more">Read the About page →</a>
        </p>
      </div>
      <div class="about__col ar" lang="ar" dir="rtl">
        <p>
          «مدار» مجلّةٌ تحريريّةٌ بطيئةُ الإيقاع تَتناولُ التعليمَ في مرحلتَيِ
          الطفولةِ المبكّرةِ والتعليمِ العامّ، تَصدرُ بالعربيّةِ والإنجليزيّة.
          نَنشرُ نوعَين من المواد: <em>تقاريرَ ميدانيّة</em> نَكتبُها بأنفسنا،
          و<em>قراءاتٍ مختاَرة</em> لمصدرٍ واحدٍ يَستحقّ الإصغاء. قطعتان أو ثلاث
          في كلّ عدد. عددٌ واحدٌ كلّ شهر. أداةُ بحثٍ، لا مجلّةً.
        </p>
        <p>
          <a href={withBase('/ar/')} class="about__more">اقرأ صفحةَ «عن مدار» ←</a>
        </p>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ---------- Top utility bar ---------- */
  .top-bar {
    border-block-end: 1px solid var(--color-rule-soft);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .top-bar__inner {
    padding-block: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .top-bar__right { display: flex; gap: 1.25rem; align-items: center; }
  .top-bar__lang a { text-decoration: none; color: var(--color-ink); opacity: 0.6; }
  .top-bar__lang a.is-active { color: var(--color-orange); opacity: 1; font-weight: 500; }
  .top-bar__lang span { opacity: 0.35; }

  /* ---------- Masthead ---------- */
  .masthead {
    border-block-end: 1px solid var(--color-rule);
    padding-block: 4rem 3rem;
    text-align: center;
  }
  .masthead__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }
  .masthead__mark {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-ink);
    line-height: 1;
  }
  /* Inlined SVG wordmark — inherits currentColor (var(--color-ink)). */
  .masthead__mark :global(svg) {
    width: auto;
    height: 120px;
    display: block;
    color: var(--color-ink);
  }
  /* Typographic fallback (visible only if SVG fails to inline) */
  .masthead__mark-latin {
    font-family: var(--font-display);
    font-size: 88px;
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  .masthead__mark-divider {
    font-family: var(--font-display);
    font-size: 60px;
    opacity: 0.4;
  }
  .masthead__mark-arabic {
    font-family: var(--font-arabic-display);
    font-size: 76px;
    line-height: 1;
  }

  .masthead__rule {
    height: 1px;
    background: var(--color-ink);
    width: 120px;
    position: relative;
  }
  .masthead__rule::before, .masthead__rule::after {
    content: '';
    position: absolute;
    inset-block-start: -4px;
    width: 1px;
    height: 9px;
    background: var(--color-ink);
  }
  .masthead__rule::before { inset-inline-start: 0; }
  .masthead__rule::after  { inset-inline-end: 0; }

  .masthead__tagline {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.78;
    line-height: 1.8;
    max-width: 42ch;
  }
  .masthead__tagline-ar {
    display: block;
    margin-block-start: 0.4rem;
    font-family: var(--font-arabic);
    font-size: 17px;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1.6;
    color: var(--color-ink);
    opacity: 0.85;
  }

  /* ---------- Section ---------- */
  .section { padding-block: 3.5rem; }
  .section__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-block-end: 2.5rem;
  }
  .section__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-orange);
    font-weight: 500;
  }
  .section__kicker-ar {
    font-family: var(--font-arabic);
    font-size: 16px;
    color: var(--color-ink);
    opacity: 0.7;
    margin-inline-start: 0.85rem;
  }
  .section__meta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.62;
  }

  .placeholder { padding-block: var(--space-lg); }
  .placeholder h2 { max-width: 28ch; margin-block-start: var(--space-sm); }
  .placeholder p { margin-block-start: var(--space-md); }

  /* ============================================================
     LEAD PIECE — substantial real estate, wide Still, generous
     headline. Mirrors the editorial hierarchy in _HOME_mockup.
     ============================================================ */
  .lead {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 3rem;
    align-items: start;
    margin-block-end: 3rem;
  }
  .lead__thumb {
    aspect-ratio: 8 / 5;
    overflow: hidden;
    display: block;
    background: var(--color-sand);
    border-radius: 1px;
    text-decoration: none;
  }
  .lead__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lead__body { display: flex; flex-direction: column; gap: 1rem; padding-block-start: 0.25rem; }
  .lead__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-orange);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .lead__label::before {
    content: '';
    display: inline-block;
    width: 22px;
    height: 1px;
    background: var(--color-orange);
    opacity: 0.85;
  }
  .lead__meta {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .lead__type { color: var(--color-ink); opacity: 0.85; font-weight: 500; }
  .lead__country { color: var(--color-ink); opacity: 0.55; }
  .lead__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 56px;
    line-height: 1.02;
    letter-spacing: -0.018em;
    margin: 0;
  }
  .lead__title em { font-style: italic; font-weight: 500; }
  .lead__title a { color: var(--color-ink); text-decoration: none; }
  .lead__title a:hover { color: var(--color-orange); }
  .lead__dek {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.5;
    font-style: italic;
    color: var(--color-ink);
    opacity: 0.82;
    margin: 0;
    max-width: 38ch;
  }
  .lead__byline {
    margin-block-start: 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-sage);
    line-height: 1.6;
  }
  .lead__read {
    margin-block-start: 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-orange);
    font-weight: 500;
    text-decoration: none;
    border-block-end: 1px solid var(--color-orange);
    padding-block-end: 2px;
    align-self: flex-start;
  }

  /* ============================================================
     SECONDARY REGISTER — two pieces under "Also this issue".
     Smaller Still thumbnails, tighter type.
     ============================================================ */
  .also {
    border-block-start: 1px solid var(--color-rule);
    padding-block-start: 2.5rem;
    margin-block-start: 1rem;
  }
  .also__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-block-end: 2rem;
  }
  .also__label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.75;
    font-weight: 500;
  }
  .also__label-ar {
    font-family: var(--font-arabic);
    font-size: 16px;
    color: var(--color-ink);
    opacity: 0.6;
    margin-inline-start: 0.85rem;
  }
  .also__meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.55;
  }
  .also__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .secondary {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 1.25rem;
    align-items: start;
  }
  .secondary__thumb {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    display: block;
    background: var(--color-sand);
    border-radius: 1px;
    text-decoration: none;
  }
  .secondary__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .secondary__body { display: flex; flex-direction: column; gap: 0.5rem; }
  .secondary__meta {
    display: flex;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .secondary__type { color: var(--color-orange); font-weight: 500; }
  .secondary__country { color: var(--color-ink); opacity: 0.6; }
  .secondary__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 21px;
    line-height: 1.12;
    letter-spacing: -0.008em;
    margin: 0;
  }
  .secondary__title em { font-style: italic; font-weight: 500; }
  .secondary__title a { color: var(--color-ink); text-decoration: none; }
  .secondary__title a:hover { color: var(--color-orange); }
  .secondary__dek {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    font-style: italic;
    color: var(--color-ink);
    opacity: 0.72;
    margin: 0;
  }
  .secondary__byline {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.06em;
    color: var(--color-sage);
    line-height: 1.6;
    margin-block-start: 0.2rem;
  }

  /* ---------- Macron divider ---------- */
  .macron-divider {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: flex;
    justify-content: center;
    margin-block: 1.5rem;
  }
  .macron-divider__rule {
    display: block;
    width: 80px;
    height: 1px;
    background: var(--color-ink);
    position: relative;
    opacity: 0.85;
  }
  .macron-divider__rule::before, .macron-divider__rule::after {
    content: '';
    position: absolute;
    inset-block-start: -4px;
    width: 1px;
    height: 9px;
    background: var(--color-ink);
  }
  .macron-divider__rule::before { inset-inline-start: 0; }
  .macron-divider__rule::after  { inset-inline-end: 0; }

  /* ---------- About mini-block ---------- */
  .about {
    padding-block: 3rem 4rem;
    display: grid;
    grid-template-columns: 3fr 9fr;
    gap: 3rem;
  }
  .about__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-orange);
    font-weight: 500;
    margin: 0;
  }
  .about__label-ar {
    font-family: var(--font-arabic);
    font-size: 18px;
    color: var(--color-ink);
    opacity: 0.75;
    margin-block-start: 0.3rem;
  }
  .about__body { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .about__col p {
    font-family: var(--font-body);
    font-size: 17.5px;
    line-height: 1.65;
    margin: 0 0 1rem;
    color: var(--color-ink);
    opacity: 0.92;
    max-width: 52ch;
  }
  .about__col.ar p {
    font-family: var(--font-arabic);
    font-size: 18.5px;
    line-height: 1.95;
  }
  .about__more {
    margin-block-start: 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
